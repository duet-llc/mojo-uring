#!/bin/bash
set -euo pipefail

# Get staged .mojo files (Added, Copied, Modified, Renamed)
STAGED_MOJO_FILES=$(git diff --staged --name-only --diff-filter=ACMR -- '*.mojo')

# If there are staged .mojo files, format them
if [ -n "$STAGED_MOJO_FILES" ]; then
  mojo format --quiet $STAGED_MOJO_FILES
  # Re-stage the formatted files
  git add $STAGED_MOJO_FILES
fi

# Run tests before allowing commit
./test/run.sh
